<vector xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">
    
    <!-- Outer Cinematic Neon Glow Ring -->
    <path
        android:strokeWidth="1.5"
        android:strokeColor="#FFC107"
        android:pathData="M54,18 A36,36 0 1,1 53.9,18 Z"
        android:fillColor="#00000000" />

    <!-- Stylized Red Play Triangle -->
    <path
        android:pathData="M44,36 L72,54 L44,72 Z">
        <aapt:attr name="android:fillColor">
            <gradient
                android:startX="44"
                android:startY="36"
                android:endX="72"
                android:endY="72"
                android:type="linear">
                <item android:color="#E50914" android:offset="0.0" />
                <item android:color="#9C050D" android:offset="1.0" />
            </gradient>
        </aapt:attr>
    </path>

    <!-- Bold Stylish "V" Badge Overlay across the play button -->
    <path
        android:pathData="M32,32 L44,66 L56,32 H48 L44,52 L40,32 Z">
        <aapt:attr name="android:fillColor">
            <gradient
                android:startX="32"
                android:startY="32"
                android:endX="56"
                android:endY="66"
                android:type="linear">
                <item android:color="#FFD700" android:offset="0.0" />
                <item android:color="#FF8C00" android:offset="1.0" />
            </gradient>
        </aapt:attr>
    </path>
</vector>

